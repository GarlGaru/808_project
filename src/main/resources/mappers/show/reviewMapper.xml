<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.spring.eze.show.dao.review.ReviewDAO">

    <!-- ========================= -->
    <!-- 1. ResultMap -->
    <!-- ========================= -->
    <resultMap id="reviewMap" type="com.spring.eze.show.dto.review.ReviewDTO">
        <id property="reviewId" column="review_id"/>
        <result property="userNum" column="user_id"/>
        <result property="showId" column="show_id"/>
        <result property="rating" column="rating"/>
        <result property="content" column="content"/>
        <result property="createdAt" column="created_at"/>

        <!-- JOIN 컬럼 -->
        <result property="nickname" column="nickname"/>
        <result property="concertTitle" column="title"/>
    </resultMap>


    <!-- ========================= -->
    <!-- 2. 후기 전체 목록 -->
    <!-- ========================= -->
    <select id="getReviewList" resultMap="reviewMap">
        SELECT
            r.review_id,
            r.user_id,
            r.show_id,
            r.rating,
            r.content,
            r.created_at,
            u.nickname,
            s.title
        FROM review_tbl r
        LEFT JOIN user_tbl u ON r.user_id = u.user_id
        LEFT JOIN show_tbl s ON r.show_id = s.show_id
        ORDER BY r.review_id DESC
    </select>


    <!-- ========================= -->
    <!-- 3. 공연별 후기 목록 -->
    <!-- ========================= -->
    <select id="getReviewByShowId"
            parameterType="string"
            resultMap="reviewMap">
        SELECT
            r.review_id,
            r.user_id,
            r.show_id,
            r.rating,
            r.content,
            r.created_at,
            u.nickname,
            s.title
        FROM review_tbl r
        LEFT JOIN user_tbl u ON r.user_id = u.user_id
        LEFT JOIN show_tbl s ON r.show_id = s.show_id
        WHERE r.show_id = #{showId}
        ORDER BY r.review_id DESC
    </select>


    <!-- ========================= -->
    <!-- 4. 전체 개수 -->
    <!-- ========================= -->
    <select id="getTotalCount" resultType="int">
        SELECT COUNT(*) FROM review_tbl
    </select>


    <!-- ========================= -->
    <!-- 5. 상세 보기 -->
    <!-- ========================= -->
    <select id="getReviewDetail"
            parameterType="int"
            resultMap="reviewMap">
        SELECT
            r.review_id,
            r.user_id,
            r.show_id,
            r.rating,
            r.content,
            r.created_at,
            u.nickname,
            s.title
        FROM review_tbl r
        LEFT JOIN user_tbl u ON r.user_id = u.user_id
        LEFT JOIN show_tbl s ON r.show_id = s.show_id
        WHERE r.review_id = #{reviewId}
    </select>


    <!-- ========================= -->
    <!-- 6. 후기 작성 -->
    <!-- ========================= -->
    <insert id="insertReview"
            parameterType="com.spring.eze.show.dto.review.ReviewDTO">
        INSERT INTO review_tbl (
            review_id,
            user_id,
            show_id,
            rating,
            content,
            created_at
        )
        VALUES (
            review_seq.NEXTVAL,
            #{userId},
            #{showId},
            #{rating},
            #{content},
            SYSDATE
        )
    </insert>


    <!-- ========================= -->
    <!-- 7. 후기 수정 -->
    <!-- ========================= -->
    <update id="updateReview"
            parameterType="com.spring.eze.show.dto.review.ReviewDTO">
        UPDATE review_tbl
        SET
            content = #{content},
            rating = #{rating}
        WHERE review_id = #{reviewId}
    </update>


    <!-- ========================= -->
    <!-- 8. 후기 삭제 -->
    <!-- ========================= -->
    <delete id="deleteReview"
            parameterType="int">
        DELETE FROM review_tbl
        WHERE review_id = #{reviewId}
    </delete>
    
    <select id="getShowListForReview" resultType="com.spring.eze.show.dto.review.ReviewDTO">
    SELECT 
        show_id as showId, 
        title as concertTitle 
    FROM show_tbl
    ORDER BY title ASC
</select>


</mapper>